<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleShortVersionString</key>
	<string>1.0</string>
	<key>CFBundleVersion</key>
	<string>1</string>
	<key>CFBundleDevelopmentRegion</key>
	<string>en</string>
	<!--
	  Declares the bundle's supported localizations so iOS treats the app as
	  localized and surfaces a per-app language picker in Settings > Ratatoskr >
	  Language. Keep in lockstep with `androidApp/src/main/res/xml/locales_config.xml`
	  and the Compose Resources `values-*` directories in
	  `core/ui/src/commonMain/composeResources/`.
	-->
	<key>CFBundleLocalizations</key>
	<array>
		<string>en</string>
		<string>ru</string>
	</array>
	<key>CADisableMinimumFrameDurationOnPhone</key>
	<true/>

	<!-- Background Modes -->
	<key>UIBackgroundModes</key>
	<array>
		<string>processing</string>
		<string>fetch</string>
	</array>

	<!-- Background Task Scheduler Identifiers -->
	<key>BGTaskSchedulerPermittedIdentifiers</key>
	<array>
		<string>com.po4yka.ratatoskr.sync</string>
	</array>
	<!-- Deep Link URL Scheme for Widgets -->
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>ratatoskr</string>
			</array>
			<key>CFBundleURLName</key>
			<string>com.po4yka.ratatoskr</string>
		</dict>
	</array>
</dict>
</plist>
